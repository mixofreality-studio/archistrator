# =============================================================================
# archistrator webApp — environment configuration (Vite reads VITE_* at build).
# Copy to `.env` (or `.env.local`) and adjust. Do NOT commit secrets.
# =============================================================================

# --- API ---------------------------------------------------------------------
# Origin prefix placed BEFORE the "/api/..." request paths. Leave empty for
# same-origin (dev: Vite proxies /api → localhost:8888; prod: Envoy routes
# /api/* → archistrator-server). Set to a full origin (e.g. http://localhost:8888)
# only for cross-origin dev against a remote server.
VITE_API_BASE_URL=

# --- Auth mode ---------------------------------------------------------------
# Auth is handled at the Envoy edge (GTD parity): the edge runs the Keycloak OIDC
# redirect login, sets the session cookie, and forwards the validated access token
# to the server. The SPA never runs its own OIDC flow — it only probes
# GET /api/userinfo. This flag only toggles a clearly-labelled DEV badge:
#   "dev"      → no edge in front; the server injects an env-gated dev principal,
#                so /api/userinfo returns it. Locally runnable with no IdP.
#   "keycloak" → real edge-OIDC deployment.
# (There are NO VITE_OIDC_* settings anymore — the edge owns all OIDC config.)
VITE_AUTH_MODE=dev
