# Local dev — DRYRUN=false construction run
# Fill in the PLACEHOLDER values before starting the server.

# HTTP — vite dev proxy targets :8888
ARCHISTRATOR_LISTEN_ADDR=:8888

# Temporal — local dev server already running
ARCHISTRATOR_TEMPORAL_HOSTPORT=localhost:7233
ARCHISTRATOR_TEMPORAL_NAMESPACE=default

# Postgres — systemtests container (localhost:5432)
ARCHISTRATOR_POSTGRES_URL=postgres://archistrator:archistrator@localhost:5432/archistrator

# Auth — dev mode (no Keycloak locally)
ARCHISTRATOR_AUTH_DEV_MODE=true

# Worker
ARCHISTRATOR_WORKER_PROVIDER=anthropic
ARCHISTRATOR_ANTHROPIC_API_KEY=PLACEHOLDER
ARCHISTRATOR_ANTHROPIC_MODEL=claude-opus-4-8
ARCHISTRATOR_ANTHROPIC_ARCHITECT_MODEL=claude-opus-4-8
ARCHISTRATOR_ANTHROPIC_CRITIQUE_MODEL=claude-sonnet-4-6

# Construction — DRYRUN=false (real GitHub Actions dispatch)
ARCHISTRATOR_CONSTRUCTION_DRYRUN=false
ARCHISTRATOR_GITHUB_APP_ID=4112774
ARCHISTRATOR_GITHUB_APP_PRIVATE_KEY_PEM=/Users/davidmarne/Downloads/archistrator-bot.2026-06-21.private-key.pem
ARCHISTRATOR_CONSTRUCTION_REPO_OWNER=mixofreality-studio
ARCHISTRATOR_CONSTRUCTION_REPO_NAME=archistrator
ARCHISTRATOR_CONSTRUCTION_WORKFLOW_FILE=aiarch-construct.yml
ARCHISTRATOR_CONSTRUCTION_REF=main

# Artifact store — cloud (same GitHub App token)
ARCHISTRATOR_ARTIFACT_REPO_URL=https://github.com/mixofreality-studio/archistrator.git
ARCHISTRATOR_ARTIFACT_REPO_OWNER=mixofreality-studio

# Project state — local git repo (the seeded archistrator repo)
ARCHISTRATOR_PROJECT_STATE_GIT_LOCAL=true
ARCHISTRATOR_PROJECT_STATE_GIT_REPO_URL=file:///Users/davidmarne/mixofrealitystudio/archistrator
