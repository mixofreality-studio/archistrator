{
  "$id": "archistrator://contract/estimation",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ActivityItem": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "effortDays": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "effortDays"
      ],
      "additionalProperties": false
    },
    "ActivityList": {
      "type": "object",
      "properties": {
        "activities": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ActivityItem"
          }
        }
      },
      "required": [
        "activities"
      ],
      "additionalProperties": false
    },
    "ActivityNetwork": {
      "type": "object",
      "properties": {
        "activities": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/OptionActivity"
          }
        }
      },
      "required": [
        "activities"
      ],
      "additionalProperties": false
    },
    "ConstructionEstimate": {
      "type": "object",
      "properties": {
        "DurationDays": {
          "type": "number"
        },
        "BuildCost": {
          "$ref": "#/$defs/Money"
        },
        "Risk": {
          "$ref": "#/$defs/RiskScore"
        }
      },
      "required": [
        "DurationDays",
        "BuildCost",
        "Risk"
      ],
      "additionalProperties": false
    },
    "Money": {
      "type": "object",
      "properties": {
        "minorUnits": {
          "type": "integer"
        },
        "currency": {
          "type": "string"
        }
      },
      "required": [
        "minorUnits",
        "currency"
      ],
      "additionalProperties": false
    },
    "Network": {
      "type": "object",
      "properties": {
        "dependencies": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/NetworkDependency"
          }
        },
        "milestones": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/NetworkMilestone"
          }
        }
      },
      "required": [
        "dependencies"
      ],
      "additionalProperties": false
    },
    "NetworkDependency": {
      "type": "object",
      "properties": {
        "activity": {
          "type": "string"
        },
        "dependsOn": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "activity",
        "dependsOn"
      ],
      "additionalProperties": false
    },
    "NetworkMilestone": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "dependsOn": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false
    },
    "NetworkMilestoneSolution": {
      "type": "object",
      "properties": {
        "ID": {
          "type": "string"
        },
        "OnCriticalPath": {
          "type": "boolean"
        },
        "EventTime": {
          "type": "number"
        }
      },
      "required": [
        "ID",
        "OnCriticalPath",
        "EventTime"
      ],
      "additionalProperties": false
    },
    "NetworkNode": {
      "type": "object",
      "properties": {
        "EarliestStart": {
          "type": "number"
        },
        "EarliestFinish": {
          "type": "number"
        },
        "LatestStart": {
          "type": "number"
        },
        "LatestFinish": {
          "type": "number"
        },
        "TotalFloat": {
          "type": "number"
        },
        "FreeFloat": {
          "type": "number"
        },
        "OnCriticalPath": {
          "type": "boolean"
        },
        "NearCritical": {
          "type": "boolean"
        },
        "Band": {
          "type": "string"
        },
        "Column": {
          "type": "integer"
        }
      },
      "required": [
        "EarliestStart",
        "EarliestFinish",
        "LatestStart",
        "LatestFinish",
        "TotalFloat",
        "FreeFloat",
        "OnCriticalPath",
        "NearCritical",
        "Band",
        "Column"
      ],
      "additionalProperties": false
    },
    "NetworkSolution": {
      "type": "object",
      "properties": {
        "Nodes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/NetworkNode"
          }
        },
        "Milestones": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/NetworkMilestoneSolution"
          }
        },
        "Summary": {
          "$ref": "#/$defs/NetworkSummary"
        }
      },
      "required": [
        "Nodes",
        "Milestones",
        "Summary"
      ],
      "additionalProperties": false
    },
    "NetworkSummary": {
      "type": "object",
      "properties": {
        "TotalDurationDays": {
          "type": "number"
        },
        "CriticalPathActivityCount": {
          "type": "integer"
        },
        "CriticalPathDays": {
          "type": "number"
        },
        "MaxFloat": {
          "type": "number"
        },
        "NearCriticalCount": {
          "type": "integer"
        }
      },
      "required": [
        "TotalDurationDays",
        "CriticalPathActivityCount",
        "CriticalPathDays",
        "MaxFloat",
        "NearCriticalCount"
      ],
      "additionalProperties": false
    },
    "OptionActivity": {
      "type": "object",
      "properties": {
        "activityId": {
          "type": "string"
        },
        "effortDays": {
          "type": "number"
        },
        "workerClass": {
          "type": "string"
        },
        "onCriticalPath": {
          "type": "boolean"
        },
        "riskBucket": {
          "type": "integer"
        }
      },
      "required": [
        "activityId",
        "effortDays",
        "workerClass",
        "onCriticalPath",
        "riskBucket"
      ],
      "additionalProperties": false
    },
    "OptionID": {
      "type": "string"
    },
    "ProjectOption": {
      "type": "object",
      "properties": {
        "optionId": {
          "$ref": "#/$defs/OptionID"
        },
        "network": {
          "$ref": "#/$defs/ActivityNetwork"
        },
        "workerMix": {
          "$ref": "#/$defs/WorkerMix"
        },
        "calendarDaysPerWeek": {
          "type": "number"
        }
      },
      "required": [
        "optionId",
        "network",
        "workerMix",
        "calendarDaysPerWeek"
      ],
      "additionalProperties": false
    },
    "RiskScore": {
      "type": "object",
      "properties": {
        "Composite": {
          "type": "number"
        },
        "CriticalityRisk": {
          "type": "number"
        },
        "ActivityRisk": {
          "type": "number"
        }
      },
      "required": [
        "Composite",
        "CriticalityRisk",
        "ActivityRisk"
      ],
      "additionalProperties": false
    },
    "WorkerMix": {
      "type": "object",
      "properties": {
        "classRates": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Money"
          }
        },
        "staffingCap": {
          "type": "integer"
        }
      },
      "required": [
        "classRates",
        "staffingCap"
      ],
      "additionalProperties": false
    }
  },
  "title": "estimation contract",
  "interface": {
    "name": "EstimationEngine",
    "layer": "engine",
    "operations": [
      {
        "name": "ComputeNetwork",
        "params": [
          {
            "name": "activities",
            "schema": {
              "$ref": "#/$defs/ActivityList"
            }
          },
          {
            "name": "network",
            "schema": {
              "$ref": "#/$defs/Network"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/NetworkSolution"
        },
        "error": true
      },
      {
        "name": "EstimateForOption",
        "params": [
          {
            "name": "option",
            "schema": {
              "$ref": "#/$defs/ProjectOption"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/ConstructionEstimate"
        },
        "error": true
      }
    ]
  }
}
