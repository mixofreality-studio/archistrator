{
  "$id": "archistrator://contract/review",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ReviewChange": {
      "type": "object",
      "properties": {
        "ActivityID": {
          "type": "string"
        },
        "ComponentID": {
          "type": "string"
        },
        "ContentAddress": {
          "type": "string"
        }
      },
      "required": [
        "ActivityID",
        "ComponentID",
        "ContentAddress"
      ],
      "additionalProperties": false
    },
    "ReviewSet": {
      "type": "object",
      "properties": {
        "Reviewers": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/Reviewer"
          }
        }
      },
      "required": [
        "Reviewers"
      ],
      "additionalProperties": false
    },
    "Reviewer": {
      "type": "object",
      "properties": {
        "MayAmend": {
          "type": "boolean"
        },
        "Perspective": {
          "type": "string"
        },
        "ReferenceArtifact": {
          "type": "string"
        },
        "Role": {
          "type": "string"
        }
      },
      "required": [
        "MayAmend",
        "Perspective",
        "ReferenceArtifact",
        "Role"
      ],
      "additionalProperties": false
    }
  },
  "title": "review contract",
  "interface": {
    "name": "ReviewEngine",
    "operations": [
      {
        "name": "ProposeReviews",
        "params": [
          {
            "name": "change",
            "schema": {
              "$ref": "#/$defs/ReviewChange"
            }
          },
          {
            "name": "componentID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "artifactKind",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "architectureGraph",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contracts",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/ReviewSet"
        },
        "error": true
      }
    ]
  }
}
