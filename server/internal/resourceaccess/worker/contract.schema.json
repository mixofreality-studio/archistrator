{
  "$id": "archistrator://contract/worker",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "AssistantTurn": {
      "type": "object",
      "properties": {
        "text": {
          "type": [
            "null",
            "string"
          ]
        },
        "toolCalls": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ToolCall"
          }
        },
        "stopReason": {
          "type": "string"
        }
      },
      "required": [
        "stopReason"
      ],
      "additionalProperties": false
    },
    "GenerateSpec": {
      "type": "object",
      "properties": {
        "WorkerClass": {
          "$ref": "#/$defs/WorkerClass"
        },
        "Prompt": {
          "type": "string"
        },
        "Tools": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ToolSpec"
          }
        },
        "Context": {
          "type": "string",
          "contentEncoding": "base64",
          "x-go-type": "[]byte"
        }
      },
      "required": [
        "WorkerClass",
        "Prompt",
        "Tools",
        "Context"
      ],
      "additionalProperties": false
    },
    "Message": {
      "type": "object",
      "properties": {
        "role": {
          "type": "string"
        },
        "text": {
          "type": [
            "null",
            "string"
          ]
        },
        "toolCalls": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ToolCall"
          }
        },
        "toolResults": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ToolResult"
          }
        }
      },
      "required": [
        "role"
      ],
      "additionalProperties": false
    },
    "ToolCall": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "input": {
          "type": [
            "null"
          ],
          "x-go-import": "encoding/json",
          "x-go-type": "json.RawMessage"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false
    },
    "ToolResult": {
      "type": "object",
      "properties": {
        "toolCallId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "isError": {
          "type": [
            "null",
            "boolean"
          ]
        }
      },
      "required": [
        "toolCallId",
        "content"
      ],
      "additionalProperties": false
    },
    "ToolSpec": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "inputSchema": {
          "type": [
            "null"
          ],
          "x-go-import": "encoding/json",
          "x-go-type": "json.RawMessage"
        },
        "strict": {
          "type": [
            "null",
            "boolean"
          ]
        }
      },
      "required": [
        "name",
        "description"
      ],
      "additionalProperties": false
    },
    "ToolTurnSpec": {
      "type": "object",
      "properties": {
        "WorkerClass": {
          "$ref": "#/$defs/WorkerClass"
        },
        "System": {
          "type": "string"
        },
        "Messages": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/Message"
          }
        },
        "Tools": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/ToolSpec"
          }
        }
      },
      "required": [
        "WorkerClass",
        "System",
        "Messages",
        "Tools"
      ],
      "additionalProperties": false
    },
    "WorkerClass": {
      "type": "string"
    }
  },
  "title": "worker contract",
  "interface": {
    "name": "WorkerAccess",
    "layer": "resourceaccess",
    "operations": [
      {
        "name": "Cancel",
        "params": null,
        "error": true
      },
      {
        "name": "Generate",
        "params": [
          {
            "name": "spec",
            "schema": {
              "$ref": "#/$defs/GenerateSpec"
            }
          }
        ],
        "result": {
          "x-go-import": "encoding/json",
          "x-go-type": "json.RawMessage"
        },
        "error": true
      },
      {
        "name": "GenerateToolTurn",
        "params": [
          {
            "name": "spec",
            "schema": {
              "$ref": "#/$defs/ToolTurnSpec"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/AssistantTurn"
        },
        "error": true
      }
    ]
  }
}
