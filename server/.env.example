# =============================================================================
# archistrator server — environment configuration (cmd/server/config.go).
#
# Every variable the composition root reads is documented here. Defaults shown
# are the IN-CLUSTER service addresses (namespace `archistrator`, see
# designs/aiarch/BUILD-LOCATION.md). config.go loads env ONLY in main; nothing
# deeper in the tree reads ambient env.
#
# Copy to `.env` for local `go run ./cmd/server`. Behind Envoy in-cluster these
# come from the Deployment/Secret, not a file.
# =============================================================================

# --- HTTP ---------------------------------------------------------------------
# Listen address for the webClient HTTP server. Matches the Dockerfile EXPOSE.
ARCHISTRATOR_LISTEN_ADDR=:8080
# Graceful-shutdown drain timeout (Go duration).
ARCHISTRATOR_SHUTDOWN_TIMEOUT=20s

# --- Temporal (in-cluster frontend; the Manager owns Temporal) ----------------
# operational-concepts.md §18: the Temporal cloud profile is wired to the
# in-cluster Temporal frontend.
ARCHISTRATOR_TEMPORAL_HOSTPORT=archistrator-temporal-frontend.archistrator.svc:7233
ARCHISTRATOR_TEMPORAL_NAMESPACE=default

# --- Postgres (projectStateAccess head-state) — REQUIRED ----------------------
# pgx connection string. There is NO default: loadConfig fails fast if empty.
# In-cluster RW service: archistrator-postgres-rw.archistrator.svc:5432
# Example:
ARCHISTRATOR_POSTGRES_URL=postgres://archistrator:CHANGEME@archistrator-postgres-rw.archistrator.svc:5432/archistrator?sslmode=disable

# --- Gitea (artifactAccess construction outputs) ------------------------------
# Constructed for completeness; the UC1 webClient slice does not exercise it.
# In-cluster HTTP service: archistrator-gitea-http.archistrator.svc:3000
# NOTE (UC3): when set, this ALSO backs the constructionManager's
# StoreConstructionOutput / RetrieveConstructionOutput. The construction Worker is
# registered only when BOTH this and the Argo endpoint below are configured.
ARCHISTRATOR_GITEA_REPO_URL=http://archistrator-gitea-http.archistrator.svc:3000
ARCHISTRATOR_GITEA_USERNAME=
ARCHISTRATOR_GITEA_PASSWORD=

# --- Construction (UC3) — constructionPipelineAccess (Argo Workflows on k8s) ---
# The RA speaks the plain Kubernetes REST API for the Argo Workflow CRD. When
# ARCHISTRATOR_ARGO_API_SERVER_URL is empty the pipeline RA is NOT constructed and
# the construction Worker is left dormant (GetSessionState still answers with
# empty/quiet sessions — acceptable per the C-MCN reconcile). API server endpoint:
ARCHISTRATOR_ARGO_API_SERVER_URL=
# ServiceAccount bearer token (in-cluster: the mounted SA token; out-of-band secret,
# NOT this file).
ARCHISTRATOR_ARGO_TOKEN=
# API-server CA: inline PEM, OR a path read once at boot (in-cluster: the mounted SA
# ca.crt at /var/run/secrets/kubernetes.io/serviceaccount/ca.crt). Empty ⇒ system
# roots.
ARCHISTRATOR_ARGO_CA_PEM=
ARCHISTRATOR_ARGO_CA_PATH=
# Namespace construction pipelines run in.
ARCHISTRATOR_ARGO_NAMESPACE=archistrator-construction
# The construction Manager's one Temporal task queue (must match the embedded
# Worker registration; default "construction").
ARCHISTRATOR_CONSTRUCTION_TASK_QUEUE=construction
# Concrete container image for the single logical toolchain ("go-1.23") the
# composition-root pipeline adapter emits; empty lets the RA apply its own default.
ARCHISTRATOR_CONSTRUCTION_TOOLCHAIN_IMAGE=

# --- workerAccess provider (generic typed worker) -----------------------------
# "anthropic" (production default) or "ollama" (systemtests only). The provider
# is the encapsulated Worker volatility; both build the same WorkerAccess port.
ARCHISTRATOR_WORKER_PROVIDER=anthropic
#
# Anthropic (production). API key REQUIRED when provider=anthropic; in-cluster it
# comes from the out-of-band secret archistrator-anthropic-secret (NOT this file).
ARCHISTRATOR_ANTHROPIC_API_KEY=
# Optional; empty uses the Anthropic default endpoint.
ARCHISTRATOR_ANTHROPIC_BASEURL=
# Default/fallback model + per-WorkerClass overrides (architect drafts,
# productManager critiques); resolved to a model inside the workerAccess seam.
ARCHISTRATOR_ANTHROPIC_MODEL=claude-opus-4-8
ARCHISTRATOR_ANTHROPIC_ARCHITECT_MODEL=claude-opus-4-8
ARCHISTRATOR_ANTHROPIC_CRITIQUE_MODEL=claude-sonnet-4-6
#
# Ollama (systemtests only — testcontainers / docker-compose). Required only when
# ARCHISTRATOR_WORKER_PROVIDER=ollama.
ARCHISTRATOR_OLLAMA_BASEURL=
ARCHISTRATOR_OLLAMA_MODEL=qwen2.5:3b

# --- Keycloak access-token validation -----------------------------------------
# The server validates the bearer access token itself (Envoy forwards the
# Authorization header unchanged — GTD parity). JWKS_URL is the realm certs
# endpoint (typically the INTERNAL cluster URL, fetched in-cluster); ISSUER is the
# EXTERNAL issuer the token's `iss` must match. When JWKS_URL is empty no validator
# is constructed (local dev / systemtests): dev mode injects a principal, otherwise
# every request is denied.
ARCHISTRATOR_KEYCLOAK_JWKS_URL=
ARCHISTRATOR_KEYCLOAK_ISSUER=

# --- Auth dev mode (clearly gated; MUST be OFF in any IdP-fronted deployment) ---
# When true, a dev principal is injected on every request and the access token is
# NOT validated, so the server is locally runnable end-to-end without an IdP.
# Leave false (or unset) anywhere a real token is expected.
ARCHISTRATOR_AUTH_DEV_MODE=false

# Dev principal (only used when ARCHISTRATOR_AUTH_DEV_MODE=true). Defaults are a
# user carrying the verbs the UC1 webClient authorizes (drive-phase,
# approve-artifact) so the deny-by-default PDP permits the happy path locally.
ARCHISTRATOR_DEV_SUBJECT=dev-architect
ARCHISTRATOR_DEV_ROLES=drive-phase approve-artifact
